# Whoogle Search - Railway Template Environment Variables
# Configure your privacy-respecting metasearch engine

# === Basic Configuration ===

# URL prefix for serving Whoogle under a subpath (e.g., "/whoogle")
WHOOGLE_URL_PREFIX=

# Basic authentication credentials (optional - leave blank to disable)
WHOOGLE_USER=
WHOOGLE_PASS=

# === Proxy Configuration ===

# Proxy type: "socks5", "socks4", or "http"
WHOOGLE_PROXY_TYPE=

# Proxy location: host:port
WHOOGLE_PROXY_LOC=

# Proxy authentication
WHOOGLE_PROXY_USER=
WHOOGLE_PROXY_PASS=

# === Google Custom Search Engine (BYOK) ===
# For continued searching without JavaScript, configure a CSE key:
# Get API key and CSE ID from https://programmablesearchengine.google.com
WHOOGLE_CSE_API_KEY=
WHOOGLE_CSE_ID=
WHOOGLE_USE_CSE=

# === Search Configuration ===

# Interface language (e.g., "en", "ja", "es")
WHOOGLE_CONFIG_LANGUAGE=

# Theme: "light", "dark", or "system"
WHOOGLE_CONFIG_THEME=system

# Enable safe searches (0 or 1)
WHOOGLE_CONFIG_SAFE=1

# Enable social media alternatives (0 or 1)
WHOOGLE_CONFIG_ALTS=1

# Use Tor routing for searches (0 or 1)
WHOOGLE_CONFIG_TOR=0

# === Site Alternatives ===
# Whoogle provides alternative frontends for popular sites

WHOOGLE_ALT_TW=farside.link/nitter
WHOOGLE_ALT_YT=farside.link/invidious
WHOOGLE_ALT_RD=farside.link/libreddit
WHOOGLE_ALT_MD=farside.link/scribe
WHOOGLE_ALT_TL=farside.link/lingva
WHOOGLE_ALT_IMG=farside.link/rimgo
WHOOGLE_ALT_WIKI=farside.link/wikiless
WHOOGLE_ALT_IMDB=farside.link/libremdb
WHOOGLE_ALT_QUORA=farside.link/quetre
WHOOGLE_ALT_SO=farside.link/anonymousoverflow